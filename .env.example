# Humanity Union Environment Example

NODE_ENV=development

# API
API_PORT=4000

# Web
WEB_PORT=3000

# Database
MONGODB_URI=mongodb://localhost:27017/humanity_union

# Authentication
JWT_SECRET=change_this_value
JWT_EXPIRES_IN=7d

# Platform
PLATFORM_NAME=Humanity Union
PLATFORM_URL=http://localhost:3000
